   local Scroll = Instance.new("ScrollingFrame", Main)
   Scroll.Size = UDim2.new(0.92, 0, 0, 190)
   Scroll.Position = UDim2.new(0.04, 0, 0, 115)
   Scroll.BackgroundTransparency = 1
   Scroll.ScrollBarThickness = 0
   Scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
   local ListLayout = Instance.new("UIListLayout", Scroll)
   ListLayout.Padding = UDim.new(0, 8)

   local function createTrack(target)
      if Scroll:FindFirstChild(target.Name) then return end

      local Item = Instance.new("Frame", Scroll)
      Item.Name = target.Name
      Item.Size = UDim2.new(1, 0, 0, 75)
      Item.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
      Instance.new("UICorner", Item).CornerRadius = UDim.new(0, 12)

      local Img = Instance.new("ImageLabel", Item)
      Img.Size = UDim2.new(0, 60, 0, 60)
      Img.Position = UDim2.new(0, 8, 0.5, -30)
      Img.Image = Players:GetUserThumbnailAsync(target.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
      Instance.new("UICorner", Img).CornerRadius = UDim.new(1, 0)

      local Name = Instance.new("TextLabel", Item)
      Name.Text = target.Name
      Name.Size = UDim2.new(0, 150, 0, 25)
      Name.Position = UDim2.new(0, 75, 0.2, 0)
      Name.TextColor3 = Color3.new(1, 1, 1)
      Name.Font = Enum.Font.GothamBold
      Name.TextSize = 18
      Name.BackgroundTransparency = 1
      Name.TextXAlignment = Enum.TextXAlignment.Left

      local Info = Instance.new("TextLabel", Item)
      Info.Text = "00:00:00"
      Info.Size = UDim2.new(0, 150, 0, 20)
      Info.Position = UDim2.new(0, 75, 0.6, 0)
      Info.TextColor3 = Color3.new(1, 1, 1)
      Info.Font = Enum.Font.Gotham
      Info.TextSize = 16
      Info.BackgroundTransparency = 1
      Info.TextXAlignment = Enum.TextXAlignment.Left

      local ViewBtn = Instance.new("TextButton", Item)
      ViewBtn.Text = "👁️"
      ViewBtn.Size = UDim2.new(0, 40, 0, 40)
      ViewBtn.Position = UDim2.new(1, -95, 0.5, -20)
      ViewBtn.BackgroundColor3 = Color3.new(0,0,0)
      ViewBtn.TextColor3 = Color3.new(1,1,1)
      ViewBtn.TextSize = 20
      Instance.new("UICorner", ViewBtn).CornerRadius = UDim.new(0, 10)

      local Exit = Instance.new("TextButton", Item)
      Exit.Text = "X"
      Exit.Size = UDim2.new(0, 40, 0, 40)
      Exit.Position = UDim2.new(1, -48, 0.5, -20)
      Exit.BackgroundColor3 = Color3.new(0,0,0)
      Exit.TextColor3 = Color3.fromRGB(255, 50, 50)
      Exit.Font = Enum.Font.GothamBold
      Exit.TextSize = 20
      Instance.new("UICorner", Exit).CornerRadius = UDim.new(0, 10)

      local startT = tick()
      local isViewing = false

      local loop = RunService.Heartbeat:Connect(function()
         if not target.Parent then
            Info.Text = "غير متصل بالإنترنت"
            return
         end
         local diff = tick() - startT
         Info.Text = string.format("%02d:%02d:%02d", math.floor(diff/3600), math.floor(diff/60)%60, diff%60)
      end)

      ViewBtn.MouseButton1Click:Connect(function()
         isViewing = not isViewing
         if isViewing then
            Camera.CameraSubject = target.Character.Humanoid
            ViewBtn.BackgroundColor3 = Color3.new(1,1,1)
            ViewBtn.TextColor3 = Color3.new(0,0,0)
         else
            Camera.CameraSubject = LocalPlayer.Character.Humanoid
            ViewBtn.BackgroundColor3 = Color3.new(0,0,0)
            ViewBtn.TextColor3 = Color3.new(1,1,1)
         end
      end)

      Exit.MouseButton1Click:Connect(function()
         if isViewing then Camera.CameraSubject = LocalPlayer.Character.Humanoid end
         loop:Disconnect()
         Item:Destroy()
      end)
   end

   Start.MouseButton1Click:Connect(function()
      local txt = Box.Text:lower()
      for _, p in pairs(Players:GetPlayers()) do
         if p.Name:lower():sub(1, #txt) == txt then
            createTrack(p)
            break
         end
      end
   end)
end})

